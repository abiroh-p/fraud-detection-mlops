mlruns/
mlartifacts/

# Model files
*.pkl
*.joblib
*.pt
*.onnx

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Ruff and Black cache
.ruff_cache/

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/settings.json
.idea/

# Docker
*.log
